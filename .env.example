# SOC Platform Environment Configuration
# Copy this file to .env and update values for your environment

# Docker/Compose
COMPOSE_PROJECT_NAME=soc-platform
DOCKER_NETWORK=soc-network

# Security Onion
SECURITY_ONION_VERSION=2.3.110
SECURITY_ONION_ADMIN_USER=admin
SECURITY_ONION_ADMIN_PASSWORD=ChangeMe123!
SECURITY_ONION_HOSTNAME=security-onion.local
SECURITY_ONION_PORT=8080

# Elasticsearch (used by Security Onion & Wazuh)
ELASTICSEARCH_VERSION=7.17.0
ELASTICSEARCH_JAVA_OPTS=-Xms512m -Xmx512m
ELASTICSEARCH_CLUSTER_NAME=soc-cluster
ELASTIC_PASSWORD=ChangeMe123!

# Kibana
KIBANA_VERSION=7.17.0
KIBANA_PORT=5601

# Wazuh Manager
WAZUH_VERSION=4.7.0
WAZUH_MANAGER_ADMIN_USER=admin
WAZUH_MANAGER_ADMIN_PASSWORD=ChangeMe123!
WAZUH_MANAGER_PORT=1514
WAZUH_API_PORT=55000

# Wazuh Dashboard
WAZUH_DASHBOARD_PORT=443
WAZUH_DASHBOARD_USER=admin
WAZUH_DASHBOARD_PASSWORD=ChangeMe123!

# Database
DATABASE_TYPE=postgresql
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=soc_platform
DATABASE_USER=soc_admin
DATABASE_PASSWORD=ChangeMe123!

# API Configuration
API_PORT=8000
API_HOST=0.0.0.0
DEBUG=false
LOG_LEVEL=INFO

# Compliance Configuration
COMPLIANCE_FRAMEWORK=ISO27001
AUDIT_LOGGING_ENABLED=true

# Network
NETWORK_INTERFACE=eth0
ALLOWED_CIDR=0.0.0.0/0

# Time Zone
TZ=UTC

# Backup
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30

# SSL/TLS
SSL_ENABLED=true
SSL_CERT_PATH=/etc/ssl/certs/server.crt
SSL_KEY_PATH=/etc/ssl/private/server.key

# Email (for alerts)
SMTP_SERVER=smtp.example.com
SMTP_PORT=587
SMTP_USER=alerts@example.com
SMTP_PASSWORD=ChangeMe123!
SMTP_FROM=soc-alerts@example.com

# Syslog Server
SYSLOG_SERVER_ENABLED=true
SYSLOG_SERVER_PORT=514